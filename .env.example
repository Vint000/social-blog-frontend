# ============================================================
# Blog EducaMais — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env — contém credenciais reais
# ============================================================

# Banco de dados (PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blogdb

# Backend (Express)
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blogdb?schema=public
CORS_ORIGIN=http://localhost:5173

# Frontend (Vite)
# ATENÇÃO: VITE_API_URL deve apontar para localhost (não nome do serviço Docker)
# O browser resolve essa URL fora da rede Docker
VITE_API_URL=http://localhost:3000
